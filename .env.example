# ─── SERVIDOR ──────────────────────────────────────────────
PORT=3000

# ─── GOOGLE SHEETS ─────────────────────────────────────────
# ID da planilha (na URL do Google Sheets)
SHEETS_ID=sua_planilha_id_aqui

# Nome da aba onde ficam os atendimentos
SHEETS_TAB=atendimentos

# Credenciais da Service Account (Google Cloud Console)
# Crie uma Service Account, baixe o JSON, e cole os valores abaixo
GOOGLE_CLIENT_EMAIL=sua-service-account@projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"

# ─── N8N WEBHOOKS ──────────────────────────────────────────
# Webhook que o N8N usa para RECEBER mensagens do cliente enquanto em atendimento humano
N8N_WEBHOOK_INCOMING=https://seu-n8n.com/webhook/human-incoming

# ─── META / WHATSAPP ───────────────────────────────────────
# Token da API da META (o mesmo que já está no N8N)
META_TOKEN=seu_token_meta_aqui
META_PHONE_ID=seu_phone_number_id_aqui

# ─── SEGURANÇA ─────────────────────────────────────────────
# Token para proteger o webhook que o N8N vai chamar
WEBHOOK_SECRET=troca_por_uma_string_aleatoria_aqui

# ─── UPLOADS ───────────────────────────────────────────────
# Pasta onde os arquivos ficam salvos no servidor
UPLOAD_DIR=uploads
# Tamanho máximo de arquivo (em MB)
MAX_FILE_MB=25
